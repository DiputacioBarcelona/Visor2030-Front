{
  "name": "ot-visor-2030",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "build-prod": "vue-tsc --noEmit && vite build --base=/",
    "serve": "vite preview",
    "zip": "zip -r \"dist/ot-visor2030-$(date +'%d-%m-%Y').zip\" dist/",
    "build-zip": "npm run build-prod && npm run zip",
    "process-csv": "node scripts/csvToJson",
    "process-json": "node scripts/jsonToCsv",
    "translate": "node scripts/translate"
  },
  "dependencies": {
    "@iconify/json": "^2.2.208",
    "@markdoc/markdoc": "^0.4.0",
    "@popperjs/core": "^2.11.8",
