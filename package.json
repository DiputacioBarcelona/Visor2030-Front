    "@vitalets/google-translate-api": "^9.2.1",
    "@vueuse/core": "^10.9.0",
    "@zumer/snapdom": "^1.9.7",
    "accurate-beeswarm-plot": "^1.0.12",
    "axios": "^1.6.8",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "d3": "^7.9.0",
    "d3-regression": "^1.3.10",
    "gsap": "^3.12.5",
    "motion": "^12.4.7",
    "topojson-client": "^3.1.0",
    "vue": "^3.4.27",
    "vue-i18n": "^9.13.1",
    "vue-router": "^4.3.2"
